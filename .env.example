APP_NAME=Teslog
APP_ENV=local
# Required — generate with: echo "APP_KEY=base64:$(openssl rand -base64 32)" >> .env
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database (SQLite default, or MySQL/PostgreSQL)
DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=teslog
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=predis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# Reverb (WebSocket)
# For production, generate a secret: openssl rand -base64 32
REVERB_APP_ID=teslog
REVERB_APP_KEY=teslog-key
REVERB_APP_SECRET=teslog-secret
REVERB_HOST=127.0.0.1
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
# Must be just the hostname (no https:// prefix)
VITE_REVERB_HOST=localhost
VITE_REVERB_PORT=443
VITE_REVERB_SCHEME=https

# Tesla API — register at https://developer.tesla.com
# Set "Allowed Origin" to your APP_URL (no trailing slash)
# Set "Allowed Redirect URI" to {APP_URL}/auth/tesla/callback
TESLA_CLIENT_ID=
TESLA_CLIENT_SECRET=
TESLA_REDIRECT_URI="${APP_URL}/auth/tesla/callback"
TESLA_API_URL=https://fleet-api.prd.na.vn.cloud.tesla.com
TESLA_PRIVATE_KEY_PATH=

# Docker
APP_PORT=8080

# Fleet Telemetry — public hostname your vehicle connects to on port 4443.
# Can be the same as your app hostname (fleet telemetry uses its own mTLS on port 4443).
FLEET_TELEMETRY_HOSTNAME=telemetry.example.com
FLEET_TELEMETRY_HOST=fleet-telemetry
FLEET_TELEMETRY_PORT=4443

# Teslog
TESLOG_DISTANCE_UNIT=mi
TESLOG_TEMPERATURE_UNIT=F
TESLOG_CURRENCY=USD
TESLOG_TIMEZONE=UTC
TESLOG_API_RATE_LIMIT=60
TESLOG_COMMAND_RATE_LIMIT=10
TESLOG_RAW_RETENTION_DAYS=90
TESLOG_GEOCODING_USER_AGENT=Teslog/1.0
TESLOG_HORIZON_ENABLED=true

# Mail (optional)
MAIL_MAILER=log
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="teslog@example.com"
MAIL_FROM_NAME="${APP_NAME}"
